# Copy to server/.env and fill in. server/.env is gitignored — this repo is
# public, and a committed key is a compromised key.
#
# Load it before starting the server:
#   set -a; source .env; set +a
#   uvicorn app:app --host 0.0.0.0 --port 8000

# Qualcomm Cloud AI 100 via Cirrascale's Imagine API. It speaks the OpenAI
# chat/completions shape, including image_url content, so the existing
# openai_compat backend talks to it with no code change.
TS_VLM_BACKEND=openai
TS_OPENAI_BASE_URL=https://aisuite.cirrascale.com/apis/v2
TS_OPENAI_API_KEY=your-inference-cloud-api-key
TS_OPENAI_MODEL=set-me-from-GET-/v2/models

# Laptop tier instead (Gemma 4 E4B under llama.cpp — see run-gemma.sh):
# TS_OPENAI_BASE_URL=http://localhost:8080/v1
# TS_OPENAI_API_KEY=not-needed
# TS_OPENAI_MODEL=gemma-4-e4b
