<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TactileSight" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/qualcomm_blue</item>
        <item name="colorPrimaryDark">@color/qualcomm_blue</item>
        <item name="colorAccent">@color/qualcomm_blue</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Flat, no elevation, generous touch target. -->
    <style name="Widget.TactileSight.PrimaryButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@color/surface</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="TextAppearance.TactileSight.Label" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/on_surface_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
