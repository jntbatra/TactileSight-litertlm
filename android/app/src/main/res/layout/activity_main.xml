<?xml version="1.0" encoding="utf-8"?>
<!-- Content scrolls, the press target stays pinned: the button must never be
     pushed off-screen by a long spoken sentence or a shorter device. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:fitsSystemWindows="true"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Title on the left, the mode switch pinned top right. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/subtitle"
                android:textColor="@color/on_surface_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- The globe runs the spoken setup. A symbol rather than a language
             name because the name would have to be written in *some* language,
             and the whole point of this control is reaching a user who does not
             read the one currently set. -->
        <TextView
            android:id="@+id/languageButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/globe"
            android:textSize="26sp" />

        <!-- Always visible, in both modes: a mode you cannot leave without
             clearing app data is a trap, not a mode. -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/modeSwitch"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="top"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:text="@string/mode_dev_label"
            android:textColor="@color/on_surface_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Band or phone. Top of the screen and visible in user mode because it
         changes what the app can tell you: the band measures distance, the
         phone only describes. See FrameSourceKind.measuresDistance. -->
    <TextView
        android:id="@+id/cameraLabel"
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:labelFor="@id/cameraSpinner"
        android:text="@string/label_camera" />

    <Spinner
        android:id="@+id/cameraSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <!-- Which engine answers stays visible in user mode. It is not a debug
         detail: it decides whether the frame leaves the phone, and it is the
         one thing a user may have to change when the venue network dies. -->
    <TextView
        android:id="@+id/brainLabel"
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:labelFor="@id/brainSpinner"
        android:text="@string/label_brain" />

    <Spinner
        android:id="@+id/brainSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <!-- Everything a user must never have to see or understand: where the
         frames come from, where the engine lives, and what it is asked. One
         container so the switch is a single visibility change and a control
         cannot be added here and forgotten. -->
    <LinearLayout
        android:id="@+id/devPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Only shown for a server mode: on-device has no address. -->
    <EditText
        android:id="@+id/endpointField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_endpoint"
        android:importantForAutofill="no"
        android:inputType="textUri"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="14sp" />

    <Button
        android:id="@+id/checkServerButton"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="@string/check_server"
        android:textColor="@color/qualcomm_blue"
        android:textSize="13sp" />

    <!-- Cloud only: which model the endpoint serves. Not pinned in code
         because GET /v2/models is the authority and what is deployed there
         can change without warning. -->
    <EditText
        android:id="@+id/modelField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_model"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="14sp" />

    <TextView
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:labelFor="@id/promptField"
        android:text="@string/label_prompt" />

    <!-- Dev affordance: the prompt wording is load-bearing, and rebuilding to
         try a variant is slow enough that it does not get done. Blank restores
         the built-in prompt. -->
    <EditText
        android:id="@+id/promptField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top|start"
        android:hint="@string/hint_prompt"
        android:importantForAutofill="no"
        android:inputType="textMultiLine"
        android:maxLines="6"
        android:minLines="3"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="13sp" />

    <Button
        android:id="@+id/resetPromptButton"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="@string/reset_prompt"
        android:textColor="@color/qualcomm_blue"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/captureLabel"
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:labelFor="@id/sceneSpinner"
        android:text="@string/label_capture" />

    <Spinner
        android:id="@+id/sceneSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    </LinearLayout>

    <!-- The pair as a carousel: colour and depth. Wraps to the image
         rather than stretching to fill, so the card stays the size of what it
         shows. -->
    <LinearLayout
        android:id="@+id/previewCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp">

        <!-- Explicit height: ViewPager2 requires its pages to be match_parent,
             so the card is sized here rather than by the image. -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/framePager"
            android:layout_width="match_parent"
            android:layout_height="286dp" />

        <LinearLayout
            android:id="@+id/dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:minLines="2"
        android:text="@string/status_ready"
        android:textColor="@color/on_surface"
        android:textSize="16sp" />

    </LinearLayout>
    </ScrollView>

    <!-- Band button 1, on glass. One target carrying both gestures, exactly as
         the hardware does: tap to describe, hold to ask. Two separate buttons
         were the earlier answer, on the grounds that a long-press has no edge a
         finger can feel - but the band has one button, and a screen that
         teaches a different gesture from the hardware teaches the wrong one.

         Deliberately enormous: findable by touch alone, with no need to locate
         an edge before pressing. -->
    <Button
        android:id="@+id/actionButton"
        style="@style/Widget.TactileSight.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="16dp"
        android:text="@string/action"
        android:textSize="22sp"
        android:contentDescription="@string/action_content_description" />

</LinearLayout>
