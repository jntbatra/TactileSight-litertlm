<?xml version="1.0" encoding="utf-8"?>
<!-- Content scrolls, the press target stays pinned: the button must never be
     pushed off-screen by a long spoken sentence or a shorter device. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:fitsSystemWindows="true"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/on_surface"
        android:textSize="28sp"
        android:letterSpacing="-0.02" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="28dp"
        android:text="@string/subtitle"
        android:textColor="@color/on_surface_muted"
        android:textSize="14sp" />

    <TextView
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_source" />

    <Spinner
        android:id="@+id/sourceSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    <TextView
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:labelFor="@id/brainSpinner"
        android:text="@string/label_brain" />

    <Spinner
        android:id="@+id/brainSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <!-- Only shown for a server mode: on-device has no address. -->
    <EditText
        android:id="@+id/endpointField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_endpoint"
        android:importantForAutofill="no"
        android:inputType="textUri"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="14sp" />

    <Button
        android:id="@+id/checkServerButton"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="@string/check_server"
        android:textColor="@color/qualcomm_blue"
        android:textSize="13sp" />

    <!-- Cloud only: which model the endpoint serves. Not pinned in code
         because GET /v2/models is the authority and what is deployed there
         can change without warning. -->
    <EditText
        android:id="@+id/modelField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_model"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="14sp" />

    <TextView
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:labelFor="@id/languageSpinner"
        android:text="@string/label_language" />

    <Spinner
        android:id="@+id/languageSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <TextView
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:labelFor="@id/promptField"
        android:text="@string/label_prompt" />

    <!-- Dev affordance: the prompt wording is load-bearing, and rebuilding to
         try a variant is slow enough that it does not get done. Blank restores
         the built-in prompt. -->
    <EditText
        android:id="@+id/promptField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top|start"
        android:hint="@string/hint_prompt"
        android:importantForAutofill="no"
        android:inputType="textMultiLine"
        android:maxLines="6"
        android:minLines="3"
        android:textColor="@color/on_surface"
        android:textColorHint="@color/on_surface_muted"
        android:textSize="13sp" />

    <Button
        android:id="@+id/resetPromptButton"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        android:text="@string/reset_prompt"
        android:textColor="@color/qualcomm_blue"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/captureLabel"
        style="@style/TextAppearance.TactileSight.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:labelFor="@id/sceneSpinner"
        android:text="@string/label_capture" />

    <Spinner
        android:id="@+id/sceneSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    <!-- The triplet as a carousel: colour, infrared, depth. Wraps to the image
         rather than stretching to fill, so the card stays the size of what it
         shows. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp">

        <!-- Explicit height: ViewPager2 requires its pages to be match_parent,
             so the card is sized here rather than by the image. -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/framePager"
            android:layout_width="match_parent"
            android:layout_height="286dp" />

        <LinearLayout
            android:id="@+id/dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:minLines="2"
        android:text="@string/status_ready"
        android:textColor="@color/on_surface"
        android:textSize="16sp" />

    </LinearLayout>
    </ScrollView>

    <!-- Band button 1. Full-width and tall: findable by touch alone. -->
    <Button
        android:id="@+id/describeButton"
        style="@style/Widget.TactileSight.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="16dp"
        android:text="@string/describe"
        android:contentDescription="@string/describe_content_description" />

    <!-- The same gesture the band's button 1 carries: press to describe, hold
         to ask. Two on-screen buttons rather than one long-press, because a
         long-press on a touchscreen has no edge a finger can feel, and this
         screen is also how a sighted teammate demonstrates the band. -->
    <Button
        android:id="@+id/askButton"
        style="@style/Widget.TactileSight.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="12dp"
        android:text="@string/ask"
        android:contentDescription="@string/ask_content_description" />

</LinearLayout>
