<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Speech only. No camera permission: frames are bundled captures, and the
         band sends its own (ADR-0009). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- The private-server tier is a LAN address (LM Studio, llama-server), and
         Android has blocked cleartext HTTP by default since API 28. Without
         this the app cannot reach it while the browser on the same phone can,
         which reads as "the server is down" rather than "the app is not
         allowed". A release build should narrow this to a networkSecurityConfig
         listing only the addresses it needs. -->
    <!-- Hold-to-ask (#9). Requested at the moment of the first hold rather
         than at launch, so the prompt arrives when its purpose is obvious. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Tap-to-launch, and writing the tag that does it. -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <application
        android:usesCleartextTraffic="true"
        android:name=".TactileSightApp"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TactileSight">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Tap the phone to the band and the app opens (#10).

              A custom MIME type rather than an Android Application Record:
              an AAR launches the app when it is installed and otherwise
              sends the user to the Play Store, which is no use for a
              sideloaded build. A MIME record we own is matched only by us,
              and does nothing at all when we are absent - which is the
              honest behaviour for a tag stuck to a piece of hardware.

              Why this matters for a blind user: it removes the step that
              needs sight. Finding an icon on a home screen is the one part
              of "open the app" that a screen cannot help with.
            -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.tactilesight.band" />
            </intent-filter>
        </activity>
    </application>

</manifest>
